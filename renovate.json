{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":automergeMinor",
    "schedule:weekends"
  ],
  "argocd": {
    "fileMatch": [
      "argo-registry/.+\\.yaml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "(^|/)values\\.yaml$",
      "(^|/)values-.+\\.yaml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "(^|/)manifests/.+\\.yaml$",
      "^renovate/cronjob\\.yaml$"
    ]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch updates for all packages",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Auto-merge minor updates (dev cluster)",
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require manual review for major updates; gate behind the Dependency Dashboard checkbox so PRs only open when explicitly requested",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["major-update"]
    },
    {
      "description": "Istio only supports skipping at most 2 minor versions (N-2 rule). Step minors one-by-one via the Dependency Dashboard; never auto-merge.",
      "matchPackageNames": ["base", "istiod", "gateway"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["istio-upgrade", "service-mesh-critical"]
    },
    {
      "description": "kube-prometheus-stack bundles the operator + CRDs. Step minors manually; CRD upgrades can break ServiceMonitors.",
      "matchPackageNames": ["kube-prometheus-stack"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["monitoring-critical"]
    },
    {
      "description": "Authentik releases yearly breaking versions (2024.x -> 2025.x -> 2026.x). Always require human review.",
      "matchPackageNames": ["authentik"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["auth-critical"]
    },
    {
      "description": "Group all ArgoCD infra chart updates together",
      "matchFileNames": ["argo-registry/qa/manifests/infra/**"],
      "groupName": "infrastructure-charts",
      "groupSlug": "infra-charts"
    },
    {
      "description": "Group monitoring stack updates",
      "matchPackageNames": [
        "kube-prometheus-stack",
        "loki-stack",
        "grafana"
      ],
      "groupName": "monitoring-stack",
      "groupSlug": "monitoring"
    },
    {
      "description": "Limit Longhorn to patch updates only (storage is critical)",
      "matchPackageNames": ["longhorn"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["storage-critical"]
    },
    {
      "description": "Limit Vault to patch updates only (secrets are critical)",
      "matchPackageNames": ["vault"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "labels": ["security-critical"]
    }
  ],
  "ignoreDeps": [
    "fleet-agent-rpi-k3s",
    "system-upgrade-controller"
  ]
}
